# ----------------------------------------------------------------------------
# calibre-ui environment variable template
# Copy to ".env.local" for local overrides. NEVER put real secrets in THIS file.
# ----------------------------------------------------------------------------

# Port the production server listens on.
# Railway injects PORT automatically at runtime; the start script binds it via
# `next start -p ${PORT:-3000}`, which defaults to 3000 locally when PORT is
# unset. This template documents the NAME only — leave it blank (no value).
PORT=

# Railway project/deploy token. Used ONLY by Railway's secure environment / CI
# for deploys — it is NOT read by the app at runtime. NEVER commit a real value.
# Provide it via the Railway dashboard or CI secret store. Leave blank here.
RAILWAY_TOKEN=
