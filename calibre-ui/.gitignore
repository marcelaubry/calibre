# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# testing / coverage
/coverage

# next.js
/.next/
/out/

# production build
/build
.next/standalone/
.next/cache/

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment files — NEVER commit secrets (AAP §0.1.2).
# Ignore EVERY .env variant (.env, .env.local, .env.production, .env.staging,
# .env.preview, .env.development.local, .env*.local, …) so no real secret can
# ever be committed — matches the checkpoint requirement to ignore `.env*`:
.env*
# … but DO keep the non-secret, names-only template tracked:
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# os / editor
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea
